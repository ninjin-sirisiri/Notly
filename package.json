{
  "name": "notly",
  "version": "0.1.0",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:next\" \"pnpm run dev:electron:watch\" \"pnpm run dev:electron:start\"",
    "dev:next": "next dev",
    "dev:electron:watch": "tsc -p tsconfig.electron.json --watch",
    "dev:electron:start": "wait-on dist/electron/main.js && wait-on http://localhost:3000 && nodemon --watch dist --exec \"cross-env NODE_ENV=development electron dist/electron/main.js\"",
    "build": "pnpm run build:next && pnpm run build:electron",
    "build:next": "next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "electron .",
    "dist": "pnpm run build && electron-builder",
    "dist:mac": "pnpm run build && electron-builder --mac",
    "dist:win": "pnpm run build && electron-builder --win",
    "dist:linux": "pnpm run build && electron-builder --linux",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "lint": "eslint && tsc",
    "format": "prettier . --write",
    "check": "pnpm run format && pnpm run lint",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "build": {
    "appId": "com.ubsa.notly",
    "productName": "Notly",
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "files": [
      "dist/**/*",
      "out/**/*",
      "node_modules/**/*",
      "package.json",
      "!node_modules/.prisma/client/*.node",
      "node_modules/.prisma/client/*.node"
    ],
    "asarUnpack": [
      "node_modules/.prisma",
      "node_modules/@prisma/client"
    ]
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-is-dev": "^3.0.1",
    "lucide-react": "^0.545.0",
    "motion": "^12.23.24",
    "next": "15.5.5",
    "next-themes": "^0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.6",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.7.2",
    "@types/react": "^19",
    "@types/react-dom": "^19.2.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^38.2.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "15.5.5",
    "jsdom": "^27.0.0",
    "nodemon": "^3.1.10",
    "prettier": "3.6.2",
    "prisma": "^6.17.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^7.1.10",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.1"
  }
}
